# Copy to .env and fill in. The server reads these from the environment.
# For Cloudflare R2 (recommended for the spike — zero egress):

LOCKSTEP_ADDR=:8080
LOCKSTEP_BUCKET=lockstep-demo
LOCKSTEP_PREFIX=demo
LOCKSTEP_REGION=auto
LOCKSTEP_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
LOCKSTEP_ACCESS_KEY=<R2_ACCESS_KEY_ID>
LOCKSTEP_SECRET_KEY=<R2_SECRET_ACCESS_KEY>
LOCKSTEP_PRESIGN_TTL=15m
LOCKSTEP_PATH_STYLE=true

# Backblaze B2:   LOCKSTEP_ENDPOINT=https://s3.<region>.backblazeb2.com   LOCKSTEP_REGION=<region>
# Wasabi:         LOCKSTEP_ENDPOINT=https://s3.<region>.wasabisys.com     LOCKSTEP_REGION=<region>
# MinIO (local):  LOCKSTEP_ENDPOINT=http://localhost:9000                 LOCKSTEP_REGION=us-east-1
# AWS S3:         leave LOCKSTEP_ENDPOINT empty,                          LOCKSTEP_REGION=<region>  LOCKSTEP_PATH_STYLE=false
