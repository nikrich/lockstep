# Drop this in the root of your Unreal project.
#
# `filter=lfs` routes the file's bytes through Lockstep -> your bucket.
# `lockable` marks the type as exclusive-checkout: Lockstep's locking (Phase 1)
#   and the UE plugin (Phase 2) enforce "one editor at a time" for these,
#   because binary assets cannot be merged.

# --- Unreal binary assets (lockable: no merging possible) ---
*.uasset filter=lfs diff=lfs merge=lfs -text lockable
*.umap   filter=lfs diff=lfs merge=lfs -text lockable

# --- Source art / media (lockable) ---
*.fbx  filter=lfs diff=lfs merge=lfs -text lockable
*.psd  filter=lfs diff=lfs merge=lfs -text lockable
*.blend filter=lfs diff=lfs merge=lfs -text lockable

# --- Textures / audio / video (large, but safe to fetch concurrently) ---
*.png filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
*.exr filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
